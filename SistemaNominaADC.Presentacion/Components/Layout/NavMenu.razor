@using SistemaNominaADC.Presentacion.Security
@using SistemaNominaADC.Presentacion.Services.Auth

@inject NavigationManager NavigationManager

@if (SessionService.IsAuthenticated)
{
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand sidebar-brand-logo-only" href="" title="Sistema Nómina ADC" aria-label="Sistema Nómina ADC">
                <img src="/images/logos/ADCNewLogo1.png" alt="ADC" class="sidebar-logo-tiny" />
            </a>
        </div>
    </div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="flex-column">

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu"></span>
                    Home
                </NavLink>
            </div>

            @if (menuOperaciones.Count > 0)
            {
                <div class="nav-item px-3">
                    <a class="nav-link" style="cursor:pointer" @onclick="ToggleOperacionesMenu">
                        <span class="bi bi-gear-wide-connected"></span>
                        <span class="flex-grow-1 nav-link-label">Operaciones</span>
                        <i class="bi @(expandOperacionesMenu ? "bi-chevron-down" : "bi-chevron-right")"></i>
                    </a>
                </div>

                @if (expandOperacionesMenu)
                {
                    <div class="ps-3">
                        @foreach (var objeto in menuOperaciones)
                        {
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="@objeto.Ruta.TrimStart('/')">
                                    <i class="bi @objeto.Icono"></i>
                                    <span class="nav-link-label">@objeto.Nombre</span>
                                </NavLink>
                            </div>
                        }
                    </div>
                }
            }

            @if (menuMantenimientos.Count > 0 || menuMantenimientosPlanilla.Count > 0)
            {
                <div class="nav-item px-3">
                    <a class="nav-link" style="cursor:pointer" @onclick="ToggleMantenimientosMenu">
                        <span class="bi bi-list-nested-nav-menu"></span>
                        <span class="flex-grow-1 nav-link-label">Mantenimientos</span>
                        <i class="bi @(expandMantenimientosMenu ? "bi-chevron-down" : "bi-chevron-right")"></i>
                    </a>
                </div>

                @if (expandMantenimientosMenu)
                {
                    <div class="ps-3">
                        @foreach (var objeto in menuMantenimientos)
                        {
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="@objeto.Ruta.TrimStart('/')">
                                    <i class="bi @objeto.Icono"></i>
                                    <span class="nav-link-label">@objeto.Nombre</span>
                                </NavLink>
                            </div>
                        }

                        @if (menuMantenimientosPlanilla.Count > 0)
                        {
                            <div class="nav-item px-3 mt-2">
                                <a class="nav-link" style="cursor:pointer" @onclick="() => expandMantenimientosPlanillaMenu = !expandMantenimientosPlanillaMenu">
                                    <i class="bi bi-calculator"></i>
                                    <span class="flex-grow-1 nav-link-label">Planilla</span>
                                    <i class="bi @(expandMantenimientosPlanillaMenu ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                </a>
                            </div>

                            @if (expandMantenimientosPlanillaMenu)
                            {
                                <div class="ps-3">
                                    @foreach (var objeto in menuMantenimientosPlanilla)
                                    {
                                        <div class="nav-item px-3">
                                            <NavLink class="nav-link" href="@objeto.Ruta.TrimStart('/')">
                                                <i class="bi @objeto.Icono"></i>
                                                <span class="nav-link-label">@objeto.Nombre</span>
                                            </NavLink>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            }

            @if (menuConfiguracion.Count > 0)
            {
                <div class="nav-item px-3">
                    <a class="nav-link" style="cursor:pointer" @onclick="ToggleConfiguracionMenu">
                        <i class="bi bi-sliders2"></i>
                        <span class="flex-grow-1 nav-link-label">Configuración</span>
                        <i class="bi @(expandConfiguracionMenu ? "bi-chevron-down" : "bi-chevron-right")"></i>
                    </a>
                </div>

                @if (expandConfiguracionMenu)
                {
                    <div class="ps-3">
                        @foreach (var objeto in menuConfiguracion)
                        {
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="@objeto.Ruta.TrimStart('/')">
                                    <i class="bi @objeto.Icono"></i>
                                    <span class="nav-link-label">@objeto.Nombre</span>
                                </NavLink>
                            </div>
                        }
                    </div>
                }
            }

            <hr class="text-white-50" />

            <div class="nav-item px-3 text-white-50 small">
                Usuario:
                <strong>@SessionService.UserName</strong>
            </div>

            <div class="nav-item px-3 mt-2">
                <button class="nav-link btn btn-link text-start"
                        @onclick="Logout">
                    <span class="bi bi-arrow-bar-left-nav-menu"></span>
                    Cerrar sesión
                </button>
            </div>

        </nav>
    </div>
}

