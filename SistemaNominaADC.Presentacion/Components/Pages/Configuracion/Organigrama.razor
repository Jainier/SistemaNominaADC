@page "/configuracion/organigrama"
@attribute [Authorize]

<h3>Organigrama</h3>

<div class="vista-segmentada mb-3" role="tablist" aria-label="Selector de vista">
    <button type="button" class="segment-btn @(!mostrarFormulario ? "active" : string.Empty)" @onclick="Cancelar">Listado</button>
    <button type="button" class="segment-btn @(mostrarFormulario ? "active" : string.Empty)" @onclick="Crear">Nuevo Registro</button>
</div>
@if (mostrarFormulario)
{
    <FormularioMantenimiento Titulo="@tituloFormulario"
                             Modelo="relacionActual"
                             OnValidSubmit="Guardar"
                             OnCancelar="Cancelar"
                             OnEliminar="Desactivar"
                             MostrarEliminar="@(relacionActual.IdEmpleadoJerarquia > 0)">
        <EditorTemplate Context="item">
            <div class="mb-3">
                <label class="form-label">Empleado</label>
                <InputSelect class="form-select" @bind-Value="item.IdEmpleado">
                    <option value="0">-- Seleccione --</option>
                    @foreach (var emp in empleados)
                    {
                        <option value="@emp.IdEmpleado">@emp.NombreCompleto (@emp.Cedula)</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Supervisor</label>
                <InputSelect class="form-select" @bind-Value="item.IdSupervisor">
                    <option value="0">-- Seleccione --</option>
                    @foreach (var emp in empleados.Where(e => e.IdEmpleado != item.IdEmpleado))
                    {
                        <option value="@emp.IdEmpleado">@emp.NombreCompleto (@emp.Cedula)</option>
                    }
                </InputSelect>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Vigencia Desde</label>
                    <InputDate class="form-control" @bind-Value="item.VigenciaDesde" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Vigencia Hasta</label>
                    <InputDate class="form-control" @bind-Value="item.VigenciaHasta" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control" @bind-Value="item.Observacion" rows="3" />
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" @bind="item.Activo" />
                <label class="form-check-label">Activo</label>
            </div>
        </EditorTemplate>
    </FormularioMantenimiento>
}
else
{

    <TablaMantenimiento TItem="EmpleadoJerarquia" Items="relaciones" OnRowClick="Editar">
        <ColumnsTemplate>
            <RadzenDataGridColumn TItem="EmpleadoJerarquia" Property="IdEmpleadoJerarquia" Title="ID" />
            <RadzenDataGridColumn TItem="EmpleadoJerarquia" Title="Empleado">
                <Template Context="item">@(item.Empleado?.NombreCompleto ?? item.IdEmpleado.ToString())</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmpleadoJerarquia" Title="Supervisor">
                <Template Context="item">@(item.Supervisor?.NombreCompleto ?? item.IdSupervisor.ToString())</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmpleadoJerarquia" Title="Vigencia">
                <Template Context="item">
                    @(item.VigenciaDesde?.ToString("yyyy-MM-dd") ?? "Sin inicio")
                    -
                    @(item.VigenciaHasta?.ToString("yyyy-MM-dd") ?? "Sin fin")
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmpleadoJerarquia" Title="Estado">
                <Template Context="item">@(item.Activo ? "Activo" : "Inactivo")</Template>
            </RadzenDataGridColumn>
        </ColumnsTemplate>
    </TablaMantenimiento>
}







