@page "/operaciones/permisos"
@attribute [Authorize]

<h3>Permisos</h3>

<div class="vista-segmentada mb-3" role="tablist" aria-label="Vista permisos">
    <button type="button" class="segment-btn @(!mostrarRegistro ? "active" : string.Empty)" @onclick="MostrarLista">Historial</button>
    <button type="button" class="segment-btn @(mostrarRegistro ? "active" : string.Empty)" @onclick="MostrarRegistro">Nueva Solicitud</button>
</div>

@if (mostrarRegistro)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@(idPermisoEditando.HasValue ? $"Editar Solicitud #{idPermisoEditando.Value}" : "Nueva Solicitud")</h5>
            @if (!workflowConfigurado)
            {
                <div class="alert alert-warning">
                    No hay workflow configurado para Permisos. Configure Flujos de Estado Transaccionales para habilitar registro y decisiones.
                </div>
            }

            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Empleado</label>
                    @if (esAprobador)
                    {
                        <InputSelect class="form-select" @bind-Value="idEmpleadoSeleccionado" disabled="@idPermisoEditando.HasValue">
                            <option value="0">-- Seleccione un empleado --</option>
                            @foreach (var empleado in empleados)
                            {
                                <option value="@empleado.IdEmpleado">@empleado.NombreCompleto (@empleado.Cedula)</option>
                            }
                        </InputSelect>
                    }
                    else
                    {
                        <input class="form-control" value="@(empleadoActual is null ? string.Empty : $"{empleadoActual.NombreCompleto} ({empleadoActual.Cedula})")" disabled />
                    }
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tipo de permiso</label>
                    <InputSelect class="form-select" @bind-Value="idTipoPermiso">
                        <option value="0">-- Seleccione un tipo --</option>
                        @foreach (var tipo in tiposPermiso)
                        {
                            <option value="@tipo.IdTipoPermiso">@tipo.Nombre</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Desde</label>
                    <InputDate class="form-control" @bind-Value="fechaInicio" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Hasta</label>
                    <InputDate class="form-control" @bind-Value="fechaFin" />
                </div>
            </div>

            <div class="row g-3 align-items-end mt-1">
                <div class="@(idPermisoEditando.HasValue ? "col-md-6" : "col-md-9")">
                    <label class="form-label">Motivo</label>
                    <InputText class="form-control" @bind-Value="motivo" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" @onclick="CrearSolicitud" disabled="@(procesando || !workflowConfigurado)">
                        @(idPermisoEditando.HasValue ? "Guardar Cambios" : "Solicitar Permiso")
                    </button>
                </div>
                @if (idPermisoEditando.HasValue)
                {
                    <div class="col-md-3">
                        <button class="btn btn-light border w-100" @onclick="CancelarEdicion" disabled="@procesando">Cancelar Edicion</button>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Filtros</h5>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Empleado</label>
                    @if (esAprobador)
                    {
                        <InputSelect class="form-select" @bind-Value="filtroIdEmpleado">
                            <option value="">Todos</option>
                            @foreach (var empleado in empleados)
                            {
                                <option value="@empleado.IdEmpleado">@empleado.NombreCompleto</option>
                            }
                        </InputSelect>
                    }
                    else
                    {
                        <input class="form-control" value="@(empleadoActual?.NombreCompleto ?? string.Empty)" disabled />
                    }
                </div>
                <div class="col-md-2">
                    <label class="form-label">Desde</label>
                    <InputDate class="form-control" @bind-Value="filtroDesde" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Hasta</label>
                    <InputDate class="form-control" @bind-Value="filtroHasta" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <InputSelect class="form-select" @bind-Value="filtroIdEstado">
                        <option value="">Todos</option>
                        @foreach (var estado in estados)
                        {
                            <option value="@estado.IdEstado">@estado.Nombre</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="CargarDatos">Buscar</button>
                </div>
            </div>
        </div>
    </div>

    <TablaMantenimiento TItem="Permiso"
                        Items="solicitudes"
                        OnRowClick="VerDetalle"
                        ColumnWidth="auto"
                        CssClass="tabla-autofit">
        <ColumnsTemplate>
            <RadzenDataGridColumn TItem="Permiso" Property="IdPermiso" Title="ID" />
            <RadzenDataGridColumn TItem="Permiso" FilterProperty="Empleado.NombreCompleto" Title="Empleado">
                <Template Context="item">@(item.Empleado?.NombreCompleto ?? item.IdEmpleado?.ToString() ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Permiso" FilterProperty="TipoPermiso.Nombre" Title="Tipo">
                <Template Context="item">
                    @(item.TipoPermiso?.Nombre ?? item.IdTipoPermiso?.ToString() ?? "-")
                    @if (item.TipoPermiso is not null)
                    {
                        <span class="text-muted"> - @(item.TipoPermiso.ConGoceSalarial ? "Con goce" : "Sin goce")</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Permiso" Property="FechaInicio" Title="Desde">
                <Template Context="item">@(item.FechaInicio?.ToString("yyyy-MM-dd") ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Permiso" Property="FechaFin" Title="Hasta">
                <Template Context="item">@(item.FechaFin?.ToString("yyyy-MM-dd") ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Permiso" Property="Motivo" Title="Motivo" />
            <RadzenDataGridColumn TItem="Permiso" Property="ComentarioAprobacion" Title="Comentario Aprobación" />
            <RadzenDataGridColumn TItem="Permiso" Property="IdentityUserIdDecision" Title="Gestionado por" />
            <RadzenDataGridColumn TItem="Permiso" FilterProperty="Estado.Nombre" Title="Estado">
                <Template Context="item">@(item.Estado?.Nombre ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Permiso" Title="Acciones" Width="260px">
                <Template Context="item">
                    @if (AccionesWorkflow(item).Any())
                    {
                        <div class="acciones-grid">
                            @foreach (var accion in AccionesWorkflow(item))
                            {
                                <button class="btn btn-sm @ClaseBotonAccion(accion)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => EjecutarAccionWorkflow(item, accion)">
                                    @accion
                                </button>
                            }
                        </div>
                    }
                </Template>
            </RadzenDataGridColumn>
        </ColumnsTemplate>
    </TablaMantenimiento>
}

<SolicitudDetalleModal Visible="@mostrarDetalleSolicitud"
                      Title="@tituloDetalleSolicitud"
                      Items="@detalleSolicitudItems"
                      OnClose="CerrarDetalle" />


