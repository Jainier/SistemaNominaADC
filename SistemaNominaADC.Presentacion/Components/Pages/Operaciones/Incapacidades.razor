@page "/operaciones/incapacidades"
@attribute [Authorize]

<h3>Incapacidades</h3>

<div class="vista-segmentada mb-3" role="tablist" aria-label="Vista incapacidades">
    <button type="button" class="segment-btn @(!mostrarRegistro ? "active" : string.Empty)" @onclick="MostrarLista">Historial</button>
    <button type="button" class="segment-btn @(mostrarRegistro ? "active" : string.Empty)" @onclick="MostrarRegistro">Nueva Solicitud</button>
</div>

@if (mostrarRegistro)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@(idIncapacidadEditando.HasValue ? $"Editar Solicitud #{idIncapacidadEditando.Value}" : "Nueva Solicitud")</h5>
            @if (!workflowConfigurado)
            {
                <div class="alert alert-warning">
                    No hay workflow configurado para Incapacidades. Configure Flujos de Estado Transaccionales para habilitar registro y decisiones.
                </div>
            }

            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Empleado</label>
                    @if (esAprobador)
                    {
                        <InputSelect class="form-select" @bind-Value="idEmpleadoSeleccionado" disabled="@idIncapacidadEditando.HasValue">
                            <option value="0">-- Seleccione un empleado --</option>
                            @foreach (var empleado in empleados)
                            {
                                <option value="@empleado.IdEmpleado">@empleado.NombreCompleto (@empleado.Cedula)</option>
                            }
                        </InputSelect>
                    }
                    else
                    {
                        <input class="form-control" value="@(empleadoActual is null ? string.Empty : $"{empleadoActual.NombreCompleto} ({empleadoActual.Cedula})")" disabled />
                    }
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tipo de incapacidad</label>
                    <InputSelect class="form-select" @bind-Value="idTipoIncapacidad">
                        <option value="0">-- Seleccione un tipo --</option>
                        @foreach (var tipo in tiposIncapacidad)
                        {
                            <option value="@tipo.IdTipoIncapacidad">@tipo.Nombre</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Desde</label>
                    <InputDate class="form-control" @bind-Value="fechaInicio" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Hasta</label>
                    <InputDate class="form-control" @bind-Value="fechaFin" />
                </div>
            </div>

            <div class="row g-3 align-items-end mt-1">
                <div class="col-md-3">
                    <label class="form-label">Monto cubierto</label>
                    <InputNumber class="form-control" @bind-Value="montoCubierto" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Comentario de solicitud</label>
                    <InputText class="form-control" @bind-Value="comentarioSolicitud" />
                </div>
                <div class="@(idIncapacidadEditando.HasValue ? "col-md-2" : "col-md-3")">
                    <label class="form-label">Adjunto (PDF/JPG/PNG, max. 5MB)</label>
                    <InputFile OnChange="SeleccionarAdjunto" class="form-control" />
                    @if (!string.IsNullOrWhiteSpace(nombreAdjunto))
                    {
                        <small class="text-muted">@nombreAdjunto</small>
                    }
                </div>
                <div class="@(idIncapacidadEditando.HasValue ? "col-md-2" : "col-md-3")">
                    <button class="btn btn-primary w-100" @onclick="CrearIncapacidad" disabled="@(procesando || !workflowConfigurado)">
                        @(idIncapacidadEditando.HasValue ? "Guardar Cambios" : "Registrar Incapacidad")
                    </button>
                </div>
                @if (idIncapacidadEditando.HasValue)
                {
                    <div class="col-md-2">
                        <button class="btn btn-light border w-100" @onclick="CancelarEdicion" disabled="@procesando">Cancelar Edicion</button>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Filtros</h5>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Empleado</label>
                    @if (esAprobador)
                    {
                        <InputSelect class="form-select" @bind-Value="filtroIdEmpleado">
                            <option value="">Todos</option>
                            @foreach (var empleado in empleados)
                            {
                                <option value="@empleado.IdEmpleado">@empleado.NombreCompleto</option>
                            }
                        </InputSelect>
                    }
                    else
                    {
                        <input class="form-control" value="@(empleadoActual?.NombreCompleto ?? string.Empty)" disabled />
                    }
                </div>
                <div class="col-md-2">
                    <label class="form-label">Desde</label>
                    <InputDate class="form-control" @bind-Value="filtroDesde" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Hasta</label>
                    <InputDate class="form-control" @bind-Value="filtroHasta" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <InputSelect class="form-select" @bind-Value="filtroIdEstado">
                        <option value="">Todos</option>
                        @foreach (var estado in estados)
                        {
                            <option value="@estado.IdEstado">@estado.Nombre</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="CargarDatos">Buscar</button>
                </div>
            </div>
        </div>
    </div>

    <TablaMantenimiento TItem="Incapacidad"
                        Items="incapacidades"
                        OnRowClick="VerDetalle"
                        ColumnWidth="auto"
                        CssClass="tabla-autofit">
        <ColumnsTemplate>
            <RadzenDataGridColumn TItem="Incapacidad" Property="IdIncapacidad" Title="ID" />
            <RadzenDataGridColumn TItem="Incapacidad" FilterProperty="Empleado.NombreCompleto" Title="Empleado">
                <Template Context="item">@(item.Empleado?.NombreCompleto ?? item.IdEmpleado?.ToString() ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Incapacidad" FilterProperty="TipoIncapacidad.Nombre" Title="Tipo">
                <Template Context="item">@(item.TipoIncapacidad?.Nombre ?? item.IdTipoIncapacidad?.ToString() ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Incapacidad" Property="FechaInicio" Title="Desde">
                <Template Context="item">@(item.FechaInicio?.ToString("yyyy-MM-dd") ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Incapacidad" Property="FechaFin" Title="Hasta">
                <Template Context="item">@(item.FechaFin?.ToString("yyyy-MM-dd") ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Incapacidad" Property="MontoCubierto" Title="Monto" />
            <RadzenDataGridColumn TItem="Incapacidad" Property="ComentarioSolicitud" Title="Comentario Solicitud" />
            <RadzenDataGridColumn TItem="Incapacidad" Property="ComentarioAprobacion" Title="Comentario Aprobación" />
            <RadzenDataGridColumn TItem="Incapacidad" Property="IdentityUserIdDecision" Title="Gestionado por" />
            <RadzenDataGridColumn TItem="Incapacidad" FilterProperty="Estado.Nombre" Title="Estado">
                <Template Context="item">@(item.Estado?.Nombre ?? "-")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Incapacidad" Title="Adjunto">
                <Template Context="item">
                    @if (!string.IsNullOrWhiteSpace(item.NombreDocumento))
                    {
                        <button class="btn btn-link p-0" @onclick:stopPropagation="true" @onclick="() => VerAdjunto(item.IdIncapacidad)">Ver archivo</button>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Incapacidad" Title="Acciones" Width="260px">
                <Template Context="item">
                    <div class="acciones-grid">
                        @foreach (var accion in AccionesWorkflow(item))
                        {
                            <button class="btn btn-sm @ClaseBotonAccion(accion)"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => EjecutarAccionWorkflow(item, accion)">
                                @accion
                            </button>
                        }
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </ColumnsTemplate>
    </TablaMantenimiento>
}

<SolicitudDetalleModal Visible="@mostrarDetalleSolicitud"
                      Title="@tituloDetalleSolicitud"
                      Items="@detalleSolicitudItems"
                      OnClose="CerrarDetalle" />


